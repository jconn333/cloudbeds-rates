CLOUDBEDS_PROPERTY_NAME="Berlin Encore Hotel & Suites"
CLOUDBEDS_API_KEY="cbat_REPLACE_ME"
CLOUDBEDS_PROPERTY_ID="196343"

# Optional explicit aliases for switching between properties in the UI.
CLOUDBEDS_DEFAULT_PROPERTY="berlin-encore"
CLOUDBEDS_BERLIN_ENCORE_API_KEY="cbat_REPLACE_ME"
CLOUDBEDS_BERLIN_ENCORE_PROPERTY_ID="196343"
CLOUDBEDS_BERLIN_ENCORE_PROPERTY_NAME="Berlin Encore Hotel & Suites"
CLOUDBEDS_BERLIN_RESORT_API_KEY="cbat_REPLACE_ME"
CLOUDBEDS_BERLIN_RESORT_PROPERTY_ID="304361"
CLOUDBEDS_BERLIN_RESORT_PROPERTY_NAME="Berlin Resort"

# Leave disabled for preview-only operation.
ENABLE_CLOUDBEDS_WRITES=false

# Optional; defaults to 3787.
HOST=127.0.0.1
PORT=3787

# Optional; use this on a VPS if durable state should live outside the repo.
CLOUDBEDS_RATES_DATA_DIR="./data"

# Optional daily automation settings for scripts/daily-run.mjs.
DAILY_RUN_PROPERTIES="berlin-encore,berlin-resort"
DAILY_RUN_START_OFFSET_DAYS=364
DAILY_RUN_DAYS_AHEAD=1
DAILY_RUN_OPERATOR="daily-run"
DAILY_RUN_PRE_APPLY_BACKUP=true
DAILY_RUN_VERIFY_ROLLBACK_READINESS=true
DAILY_RUN_LOCK_STALE_MINUTES=240
APPLY_LOCK_STALE_MINUTES=240
# Optional Slack/Discord-compatible webhook receiving {"text": "..."} JSON.
DAILY_RUN_WEBHOOK_URL=""
# Optional shell command for off-box backup sync. It receives DAILY_RUN_SYNC_* env vars.
DAILY_RUN_BACKUP_SYNC_COMMAND=""

# Conservative batch limits. Increase only after testing.
MAX_FETCH_DAYS=45
MAX_DRAFT_DAYS=1
MAX_DRAFT_CHANGES=20
MAX_APPLY_CHANGES=20

# Write-time rate guards. Smooth drafts may only remove cents, and all draft
# types must stay within the absolute proposed-rate range.
MIN_ALLOWED_RATE=1
MAX_ALLOWED_RATE=999.99
MAX_SMOOTH_RATE_DECREASE=0.99
